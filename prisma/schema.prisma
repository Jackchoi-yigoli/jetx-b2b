// JetX B2B Car Wash Management Platform — Prisma Schema
// ~50 enums, ~46 models, PostgreSQL (Supabase)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

